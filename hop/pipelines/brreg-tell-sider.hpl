<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>brreg-tell-sider</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Henter første side fra brreg-API-et for å lese page.totalPages, og setter variabelen TOTAL_PAGES. Antall sider gjelder kun delta-settet (enheter med oppdateringsid &gt; LAST_OPPDATERINGSID).</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>BRREG_API</name>
        <default_value>https://data.brreg.no/enhetsregisteret/api/enheter</default_value>
        <description>Basis-URL for enhetsregisteret</description>
      </parameter>
      <parameter>
        <name>PAGE_SIZE</name>
        <default_value>500</default_value>
        <description>Antall enheter per side</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/16 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/16 00:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop>
      <from>Variabler</from>
      <to>Konstanter</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Konstanter</from>
      <to>Hent side 0</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Hent side 0</from>
      <to>Parse totalPages</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parse totalPages</from>
      <to>Sett TOTAL_PAGES</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transforms>
    <transform>
      <name>Variabler</name>
      <type>GetVariable</type>
      <description/>
      <fields>
        <field>
          <name>last_oppdateringsid</name>
          <variable>${LAST_OPPDATERINGSID}</variable>
          <type>Integer</type>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <trim_type>none</trim_type>
        </field>
        <field>
          <name>page_size</name>
          <variable>${PAGE_SIZE}</variable>
          <type>Integer</type>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <trim_type>none</trim_type>
        </field>
      </fields>
      <attributes/>
      <GUI>
        <xloc>112</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Konstanter</name>
      <type>Constant</type>
      <description/>
      <fields>
        <field>
          <name>side</name>
          <type>Integer</type>
          <nullif>0</nullif>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <set_empty_string>N</set_empty_string>
        </field>
        <field>
          <name>sort</name>
          <type>String</type>
          <nullif>oppdateringsid,asc</nullif>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <set_empty_string>N</set_empty_string>
        </field>
      </fields>
      <attributes/>
      <GUI>
        <xloc>288</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Hent side 0</name>
      <type>Rest</type>
      <description/>
      <applicationType>JSON</applicationType>
      <method>GET</method>
      <url>${BRREG_API}</url>
      <urlInField>N</urlInField>
      <urlField/>
      <dynamicMethod>N</dynamicMethod>
      <methodFieldName/>
      <bodyField/>
      <httpLogin/>
      <httpPassword/>
      <proxyHost/>
      <proxyPort/>
      <preemptive>N</preemptive>
      <connectionTimeout/>
      <readTimeout/>
      <trustStoreFile/>
      <trustStorePassword/>
      <result>
        <name>result</name>
        <code>status</code>
        <response_time/>
        <response_header/>
      </result>
      <headers/>
      <parameters>
        <parameter>
          <field>side</field>
          <name>side</name>
        </parameter>
        <parameter>
          <field>page_size</field>
          <name>size</name>
        </parameter>
        <parameter>
          <field>last_oppdateringsid</field>
          <name>oppdateringsid</name>
        </parameter>
        <parameter>
          <field>sort</field>
          <name>sort</name>
        </parameter>
      </parameters>
      <matrixParameters/>
      <attributes/>
      <GUI>
        <xloc>464</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Parse totalPages</name>
      <type>JsonInput</type>
      <description/>
      <include>N</include>
      <include_field/>
      <rownum>N</rownum>
      <addresultfile>N</addresultfile>
      <readurl>N</readurl>
      <removeSourceField>N</removeSourceField>
      <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
      <doNotFailIfNoFile>Y</doNotFailIfNoFile>
      <ignoreMissingPath>Y</ignoreMissingPath>
      <defaultPathLeafToNull>Y</defaultPathLeafToNull>
      <rownum_field/>
      <in_fields>Y</in_fields>
      <is_a_file>N</is_a_file>
      <valueField>result</valueField>
      <fields>
        <field>
          <name>totalPages</name>
          <path>$.page.totalPages</path>
          <type>Integer</type>
          <format/>
          <currency/>
          <decimal/>
          <group/>
          <length>-1</length>
          <precision>-1</precision>
          <trim_type>none</trim_type>
          <repeat>N</repeat>
        </field>
        <field>
          <name>totalElements</name>
          <path>$.page.totalElements</path>
          <type>Integer</type>
          <format/>
          <currency/>
          <decimal/>
          <group/>
          <length>-1</length>
          <precision>-1</precision>
          <trim_type>none</trim_type>
          <repeat>N</repeat>
        </field>
      </fields>
      <limit>0</limit>
      <attributes/>
      <GUI>
        <xloc>640</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Sett TOTAL_PAGES</name>
      <type>SetVariable</type>
      <description/>
      <fields>
        <field>
          <variable_name>TOTAL_PAGES</variable_name>
          <field_name>totalPages</field_name>
          <variable_type>ROOT_WORKFLOW</variable_type>
          <default_value>0</default_value>
        </field>
      </fields>
      <use_formatting>N</use_formatting>
      <attributes/>
      <GUI>
        <xloc>816</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
  </transforms>
  <attributes/>
</pipeline>
