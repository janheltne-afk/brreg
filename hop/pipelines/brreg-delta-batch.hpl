        <name>org</name>
        <path>$._embedded.oppdaterteEnheter[*].organisasjonsnummer</path>
        <type>String</type>
        <format/><currency/><decimal/><group/>
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>oppdid</name>
        <path>$._embedded.oppdaterteEnheter[*].oppdateringsid</path>
        <type>Integer</type>
        <format/><currency/><decimal/><group/>
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
