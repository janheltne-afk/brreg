    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var enhet_url = getVariable("BRREG_API","") + "/" + org;</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>enhet_url</name>
