      <field><name>revisjon_fravalg</name><path>$.r[*].revisjon.fravalgRevisjon</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>smaa_foretak</name><path>$.r[*].regnkapsprinsipper.smaaForetak</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>regnskapsregler</name><path>$.r[*].regnkapsprinsipper.regnskapsregler</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_eiendeler</name><path>$.r[*].eiendeler.sumEiendeler</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_omloepsmidler</name><path>$.r[*].eiendeler.omloepsmidler.sumOmloepsmidler</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_anleggsmidler</name><path>$.r[*].eiendeler.anleggsmidler.sumAnleggsmidler</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_egenkapital_gjeld</name><path>$.r[*].egenkapitalGjeld.sumEgenkapitalGjeld</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
