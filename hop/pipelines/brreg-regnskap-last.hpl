<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>brreg-regnskap-last</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Henter årsregnskap per organisasjonsnummer (drevet fra enheter-tabellen). Org uten regnskap gir 404 og hoppes over. Hver org kan ha flere årsregnskap; alle upsertes til regnskap (nøkkel = regnskap-id).</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter><name>REGN_API</name><default_value>https://data.brreg.no/regnskapsregisteret/regnskap</default_value><description/></parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/16 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/16 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop><from>Org-numre</from><to>Bygg URL</to><enabled>Y</enabled></hop>
    <hop><from>Bygg URL</from><to>Hent regnskap</to><enabled>Y</enabled></hop>
    <hop><from>Hent regnskap</from><to>Pakk inn</to><enabled>Y</enabled></hop>
    <hop><from>Pakk inn</from><to>Parse regnskap</to><enabled>Y</enabled></hop>
    <hop><from>Parse regnskap</from><to>Har regnskap</to><enabled>Y</enabled></hop>
    <hop><from>Har regnskap</from><to>Upsert regnskap</to><enabled>Y</enabled></hop>
    <hop><from>Har regnskap</from><to>Forkast</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Org-numre</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>Brreg</connection>
    <sql>SELECT organisasjonsnummer FROM enheter</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>112</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Bygg URL</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var regn_url = getVariable("REGN_API","") + "/" + organisasjonsnummer;</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>regn_url</name>
        <rename>regn_url</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI><xloc>272</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Hent regnskap</name>
    <type>Rest</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>16</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <applicationType>JSON</applicationType>
    <method>GET</method>
    <url/>
    <urlInField>Y</urlInField>
    <dynamicMethod>N</dynamicMethod>
    <methodFieldName/>
    <urlField>regn_url</urlField>
    <bodyField/>
    <httpLogin/>
    <httpPassword>Encrypted </httpPassword>
    <proxyHost/>
    <proxyPort/>
    <preemptive>N</preemptive>
    <trustStoreFile/>
    <trustStorePassword>Encrypted </trustStorePassword>
    <ignoreSsl>N</ignoreSsl>
    <headers>
</headers>
    <parameters>
</parameters>
    <matrixParameters>
</matrixParameters>
    <result>
      <name>result</name>
      <code>status</code>
      <response_time/>
      <response_header/>
    </result>
    <attributes/>
    <GUI><xloc>432</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Pakk inn</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var wrapped = "{\"r\":[]}"; if (result != null) { var s = String(result); if (s.length &gt; 0 &amp;&amp; s.charAt(0) === "[") { wrapped = "{\"r\":" + s + "}"; } }</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>wrapped</name>
        <rename>wrapped</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI><xloc>512</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Parse regnskap</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>Y</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field><name>id</name><path>$.r[*].id</path><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>organisasjonsnummer</name><path>$.r[*].virksomhet.organisasjonsnummer</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>journalnr</name><path>$.r[*].journalnr</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>regnskapstype</name><path>$.r[*].regnskapstype</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>organisasjonsform</name><path>$.r[*].virksomhet.organisasjonsform</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>morselskap</name><path>$.r[*].virksomhet.morselskap</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>regnskapsperiode_fra</name><path>$.r[*].regnskapsperiode.fraDato</path><type>Date</type><format>yyyy-MM-dd</format><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>regnskapsperiode_til</name><path>$.r[*].regnskapsperiode.tilDato</path><type>Date</type><format>yyyy-MM-dd</format><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>valuta</name><path>$.r[*].valuta</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>avviklingsregnskap</name><path>$.r[*].avviklingsregnskap</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>oppstillingsplan</name><path>$.r[*].oppstillingsplan</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
