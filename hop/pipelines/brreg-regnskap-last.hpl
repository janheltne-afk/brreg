      <field><name>sum_gjeld</name><path>$.r[*].egenkapitalGjeld.gjeldOversikt.sumGjeld</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_kortsiktig_gjeld</name><path>$.r[*].egenkapitalGjeld.gjeldOversikt.kortsiktigGjeld.sumKortsiktigGjeld</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_langsiktig_gjeld</name><path>$.r[*].egenkapitalGjeld.gjeldOversikt.langsiktigGjeld.sumLangsiktigGjeld</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_driftsinntekter</name><path>$.r[*].resultatregnskapResultat.driftsresultat.driftsinntekter.sumDriftsinntekter</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>sum_driftskostnad</name><path>$.r[*].resultatregnskapResultat.driftsresultat.driftskostnad.sumDriftskostnad</path><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
