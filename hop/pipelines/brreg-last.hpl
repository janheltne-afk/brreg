<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>brreg-last</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Itererer over alle sider i delta-settet (0 .. TOTAL_PAGES-1), henter hver side fra brreg-API-et, parser enhetene og gjør en upsert (insert nye + oppdater endrede) mot tabellen enheter.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>BRREG_API</name>
        <default_value>https://data.brreg.no/enhetsregisteret/api/enheter</default_value>
        <description>Basis-URL for enhetsregisteret</description>
      </parameter>
      <parameter>
        <name>PAGE_SIZE</name>
        <default_value>500</default_value>
        <description>Antall enheter per side</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/16 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/16 00:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop>
      <from>Generer sider</from>
      <to>Sidenummer</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sidenummer</from>
      <to>Konstanter</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Konstanter</from>
      <to>Hent side</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Hent side</from>
      <to>Parse enheter</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parse enheter</from>
      <to>Hentet dato</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Hentet dato</from>
      <to>Upsert enheter</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transforms>
    <transform>
      <name>Generer sider</name>
      <type>RowGenerator</type>
      <description/>
      <fields/>
      <limit>${TOTAL_PAGES}</limit>
      <never_ending>N</never_ending>
      <interval_in_ms>5000</interval_in_ms>
      <row_time_field>now</row_time_field>
      <last_time_field>FiveSecondsAgo</last_time_field>
      <attributes/>
      <GUI>
        <xloc>112</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Sidenummer</name>
      <type>Sequence</type>
      <description/>
      <valuename>side</valuename>
      <use_database>N</use_database>
      <connection/>
      <schema/>
      <seqname>SEQ_</seqname>
      <use_counter>Y</use_counter>
      <counter_name/>
      <start_at>0</start_at>
      <increment_by>1</increment_by>
      <max_value>9999999999</max_value>
      <attributes/>
      <GUI>
        <xloc>256</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Konstanter</name>
      <type>Constant</type>
      <description/>
      <fields>
        <field>
          <name>page_size</name>
          <type>Integer</type>
          <nullif>${PAGE_SIZE}</nullif>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <set_empty_string>N</set_empty_string>
        </field>
        <field>
          <name>last_oppdateringsid</name>
          <type>Integer</type>
          <nullif>${LAST_OPPDATERINGSID}</nullif>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <set_empty_string>N</set_empty_string>
        </field>
        <field>
          <name>sort</name>
          <type>String</type>
          <nullif>oppdateringsid,asc</nullif>
          <format/>
          <length>-1</length>
          <precision>-1</precision>
          <set_empty_string>N</set_empty_string>
        </field>
      </fields>
      <attributes/>
      <GUI>
        <xloc>400</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Hent side</name>
      <type>Rest</type>
      <description/>
      <applicationType>JSON</applicationType>
      <method>GET</method>
      <url>${BRREG_API}</url>
      <urlInField>N</urlInField>
      <urlField/>
      <dynamicMethod>N</dynamicMethod>
      <methodFieldName/>
      <bodyField/>
      <httpLogin/>
      <httpPassword/>
      <proxyHost/>
      <proxyPort/>
      <preemptive>N</preemptive>
      <connectionTimeout/>
      <readTimeout/>
      <trustStoreFile/>
      <trustStorePassword/>
      <result>
        <name>result</name>
        <code>status</code>
        <response_time/>
        <response_header/>
      </result>
      <headers/>
      <parameters>
        <parameter>
          <field>side</field>
          <name>side</name>
        </parameter>
        <parameter>
          <field>page_size</field>
          <name>size</name>
        </parameter>
        <parameter>
          <field>last_oppdateringsid</field>
          <name>oppdateringsid</name>
        </parameter>
        <parameter>
          <field>sort</field>
          <name>sort</name>
        </parameter>
      </parameters>
      <matrixParameters/>
      <attributes/>
      <GUI>
        <xloc>544</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Parse enheter</name>
      <type>JsonInput</type>
      <description/>
      <include>N</include>
      <include_field/>
      <rownum>N</rownum>
      <addresultfile>N</addresultfile>
      <readurl>N</readurl>
      <removeSourceField>N</removeSourceField>
      <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
      <doNotFailIfNoFile>Y</doNotFailIfNoFile>
      <ignoreMissingPath>Y</ignoreMissingPath>
      <defaultPathLeafToNull>Y</defaultPathLeafToNull>
      <rownum_field/>
      <in_fields>Y</in_fields>
      <is_a_file>N</is_a_file>
      <valueField>result</valueField>
      <fields>
        <field>
          <name>organisasjonsnummer</name>
          <path>$._embedded.enheter[*].organisasjonsnummer</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>navn</name>
          <path>$._embedded.enheter[*].navn</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>organisasjonsform_kode</name>
          <path>$._embedded.enheter[*].organisasjonsform.kode</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>organisasjonsform_beskrivelse</name>
          <path>$._embedded.enheter[*].organisasjonsform.beskrivelse</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>naeringskode1</name>
          <path>$._embedded.enheter[*].naeringskode1.kode</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>naeringskode1_beskrivelse</name>
          <path>$._embedded.enheter[*].naeringskode1.beskrivelse</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>naeringskode2</name>
          <path>$._embedded.enheter[*].naeringskode2.kode</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>naeringskode2_beskrivelse</name>
          <path>$._embedded.enheter[*].naeringskode2.beskrivelse</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>antall_ansatte</name>
          <path>$._embedded.enheter[*].antallAnsatte</path>
          <type>Integer</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>stiftelsesdato</name>
          <path>$._embedded.enheter[*].stiftelsesdato</path>
          <type>Date</type>
          <format>yyyy-MM-dd</format><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>registreringsdato</name>
          <path>$._embedded.enheter[*].registreringsdatoEnhetsregisteret</path>
          <type>Date</type>
          <format>yyyy-MM-dd</format><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>hjemmeside</name>
          <path>$._embedded.enheter[*].hjemmeside</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>epostadresse</name>
          <path>$._embedded.enheter[*].epostadresse</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>forr_adresse</name>
          <path>$._embedded.enheter[*].forretningsadresse.adresse[0]</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>forr_postnummer</name>
          <path>$._embedded.enheter[*].forretningsadresse.postnummer</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>forr_poststed</name>
          <path>$._embedded.enheter[*].forretningsadresse.poststed</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>forr_kommune</name>
          <path>$._embedded.enheter[*].forretningsadresse.kommune</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>forr_kommunenummer</name>
          <path>$._embedded.enheter[*].forretningsadresse.kommunenummer</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>forr_land</name>
          <path>$._embedded.enheter[*].forretningsadresse.land</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>post_adresse</name>
          <path>$._embedded.enheter[*].postadresse.adresse[0]</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>post_postnummer</name>
          <path>$._embedded.enheter[*].postadresse.postnummer</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>post_poststed</name>
          <path>$._embedded.enheter[*].postadresse.poststed</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>registrert_mva</name>
          <path>$._embedded.enheter[*].registrertIMvaregisteret</path>
          <type>Boolean</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>registrert_foretaksreg</name>
          <path>$._embedded.enheter[*].registrertIForetaksregisteret</path>
          <type>Boolean</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>konkurs</name>
          <path>$._embedded.enheter[*].konkurs</path>
          <type>Boolean</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>under_avvikling</name>
          <path>$._embedded.enheter[*].underAvvikling</path>
          <type>Boolean</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>overordnet_enhet</name>
          <path>$._embedded.enheter[*].overordnetEnhet</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>institusjonell_sektor_kode</name>
          <path>$._embedded.enheter[*].institusjonellSektorkode.kode</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>institusjonell_sektor_beskrivelse</name>
          <path>$._embedded.enheter[*].institusjonellSektorkode.beskrivelse</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>sist_oppdatert</name>
          <path>$._embedded.enheter[*].sistOppdatert</path>
          <type>String</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
        <field>
          <name>oppdateringsid</name>
          <path>$._embedded.enheter[*].oppdateringsid</path>
          <type>Integer</type>
          <format/><currency/><decimal/><group/>
          <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
        </field>
      </fields>
      <limit>0</limit>
      <attributes/>
      <GUI>
        <xloc>688</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Hentet dato</name>
      <type>SystemInfo</type>
      <description/>
      <fields>
        <field>
          <name>hentet_dato</name>
          <type>system date (variable)</type>
        </field>
      </fields>
      <attributes/>
      <GUI>
        <xloc>832</xloc>
        <yloc>96</yloc>
      </GUI>
    </transform>
    <transform>
      <name>Upsert enheter</name>
      <type>InsertUpdate</type>
      <description/>
      <connection>Brreg</connection>
      <commit>500</commit>
      <update_bypassed>N</update_bypassed>
      <lookup>
        <schema/>
        <table>enheter</table>
        <key>
          <name>organisasjonsnummer</name>
          <field>organisasjonsnummer</field>
          <condition>=</condition>
          <name2/>
        </key>
        <value><name>navn</name><rename>navn</rename><update>Y</update></value>
        <value><name>organisasjonsform_kode</name><rename>organisasjonsform_kode</rename><update>Y</update></value>
        <value><name>organisasjonsform_beskrivelse</name><rename>organisasjonsform_beskrivelse</rename><update>Y</update></value>
        <value><name>naeringskode1</name><rename>naeringskode1</rename><update>Y</update></value>
        <value><name>naeringskode1_beskrivelse</name><rename>naeringskode1_beskrivelse</rename><update>Y</update></value>
        <value><name>naeringskode2</name><rename>naeringskode2</rename><update>Y</update></value>
        <value><name>naeringskode2_beskrivelse</name><rename>naeringskode2_beskrivelse</rename><update>Y</update></value>
        <value><name>antall_ansatte</name><rename>antall_ansatte</rename><update>Y</update></value>
        <value><name>stiftelsesdato</name><rename>stiftelsesdato</rename><update>Y</update></value>
        <value><name>registreringsdato</name><rename>registreringsdato</rename><update>Y</update></value>
        <value><name>hjemmeside</name><rename>hjemmeside</rename><update>Y</update></value>
        <value><name>epostadresse</name><rename>epostadresse</rename><update>Y</update></value>
        <value><name>forr_adresse</name><rename>forr_adresse</rename><update>Y</update></value>
        <value><name>forr_postnummer</name><rename>forr_postnummer</rename><update>Y</update></value>
        <value><name>forr_poststed</name><rename>forr_poststed</rename><update>Y</update></value>
        <value><name>forr_kommune</name><rename>forr_kommune</rename><update>Y</update></value>
        <value><name>forr_kommunenummer</name><rename>forr_kommunenummer</rename><update>Y</update></value>
        <value><name>forr_land</name><rename>forr_land</rename><update>Y</update></value>
        <value><name>post_adresse</name><rename>post_adresse</rename><update>Y</update></value>
        <value><name>post_postnummer</name><rename>post_postnummer</rename><update>Y</update></value>
        <value><name>post_poststed</name><rename>post_poststed</rename><update>Y</update></value>
        <value><name>registrert_mva</name><rename>registrert_mva</rename><update>Y</update></value>
        <value><name>registrert_foretaksreg</name><rename>registrert_foretaksreg</rename><update>Y</update></value>
        <value><name>konkurs</name><rename>konkurs</rename><update>Y</update></value>
        <value><name>under_avvikling</name><rename>under_avvikling</rename><update>Y</update></value>
        <value><name>overordnet_enhet</name><rename>overordnet_enhet</rename><update>Y</update></value>
        <value><name>institusjonell_sektor_kode</name><rename>institusjonell_sektor_kode</rename><update>Y</update></value>
        <value><name>institusjonell_sektor_beskrivelse</name><rename>institusjonell_sektor_beskrivelse</rename><update>Y</update></value>
