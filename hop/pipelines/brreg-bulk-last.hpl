<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>brreg-bulk-last</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Engangs full last: leser NDJSON-fil (én enhet pr. linje, laget fra /api/enheter/lastned) strømmende via CSV Input, parser hver linje og bulk-inserter til enheter. Tabellen tømmes av workflowen før last.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter><name>SEED_FILE</name><default_value>${PROJECT_HOME}/seed/enheter.ndjson</default_value><description>Sti til NDJSON-fila</description></parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/16 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/16 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop><from>Les NDJSON</from><to>Parse enhet</to><enabled>Y</enabled></hop>
    <hop><from>Parse enhet</from><to>Har data</to><enabled>Y</enabled></hop>
    <hop><from>Har data</from><to>Skriv enheter</to><enabled>Y</enabled></hop>
    <hop><from>Har data</from><to>Forkast</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Les NDJSON</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${SEED_FILE}</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>&#9;</separator>
    <enclosure/>
    <header>N</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>json_line</name>
        <type>String</type>
        <format/><currency/><decimal/><group/>
        <length>10000000</length><precision>-1</precision><trim_type>none</trim_type>
      </field>
    </fields>
    <attributes/>
    <GUI><xloc>112</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Parse enhet</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>Y</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field><name>organisasjonsnummer</name><path>$.organisasjonsnummer</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>navn</name><path>$.navn</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>organisasjonsform_kode</name><path>$.organisasjonsform.kode</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>organisasjonsform_beskrivelse</name><path>$.organisasjonsform.beskrivelse</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>naeringskode1</name><path>$.naeringskode1.kode</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>naeringskode1_beskrivelse</name><path>$.naeringskode1.beskrivelse</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>naeringskode2</name><path>$.naeringskode2.kode</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>naeringskode2_beskrivelse</name><path>$.naeringskode2.beskrivelse</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>antall_ansatte</name><path>$.antallAnsatte</path><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>stiftelsesdato</name><path>$.stiftelsesdato</path><type>Date</type><format>yyyy-MM-dd</format><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>registreringsdato</name><path>$.registreringsdatoEnhetsregisteret</path><type>Date</type><format>yyyy-MM-dd</format><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>hjemmeside</name><path>$.hjemmeside</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>epostadresse</name><path>$.epostadresse</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>forr_adresse</name><path>$.forretningsadresse.adresse[0]</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>forr_postnummer</name><path>$.forretningsadresse.postnummer</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>forr_poststed</name><path>$.forretningsadresse.poststed</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>forr_kommune</name><path>$.forretningsadresse.kommune</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>forr_kommunenummer</name><path>$.forretningsadresse.kommunenummer</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>forr_land</name><path>$.forretningsadresse.land</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>post_adresse</name><path>$.postadresse.adresse[0]</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>post_postnummer</name><path>$.postadresse.postnummer</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>post_poststed</name><path>$.postadresse.poststed</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>registrert_mva</name><path>$.registrertIMvaregisteret</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>registrert_foretaksreg</name><path>$.registrertIForetaksregisteret</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>konkurs</name><path>$.konkurs</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>under_avvikling</name><path>$.underAvvikling</path><type>Boolean</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>overordnet_enhet</name><path>$.overordnetEnhet</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>institusjonell_sektor_kode</name><path>$.institusjonellSektorkode.kode</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
      <field><name>institusjonell_sektor_beskrivelse</name><path>$.institusjonellSektorkode.beskrivelse</path><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat></field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <valueField>json_line</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <attributes/>
    <GUI><xloc>320</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Har data</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>organisasjonsnummer</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_false_to>Forkast</send_false_to>
    <send_true_to>Skriv enheter</send_true_to>
    <attributes/>
    <GUI><xloc>520</xloc><yloc>96</yloc></GUI>
  </transform>
  <transform>
    <name>Forkast</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <attributes/>
    <GUI><xloc>520</xloc><yloc>240</yloc></GUI>
  </transform>
  <transform>
    <name>Skriv enheter</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>Brreg</connection>
    <fields>
</fields>
    <ignore_errors>N</ignore_errors>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <specify_fields>N</specify_fields>
    <table>enheter_stg</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>Y</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>720</xloc><yloc>96</yloc></GUI>
  </transform>
  <attributes/>
</pipeline>
