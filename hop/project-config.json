{
  "description": "Apache Hop-prosjekt for inkrementell synkronisering av brreg-enhetsregisteret til PostgreSQL.",
  "company": "",
  "department": "",
  "metadataBaseFolder": "${PROJECT_HOME}/metadata",
  "unitTestsBasePath": "${PROJECT_HOME}",
  "dataSetsCsvFolder": "${PROJECT_HOME}/datasets",
  "enforceExecutionInHome": true,
  "configFileNamePattern": "${PROJECT_HOME}/conf/project-environment-config.json",
  "variables": [
    {
      "name": "BRREG_API",
      "value": "https://data.brreg.no/enhetsregisteret/api/enheter",
      "description": "Basis-URL for enkeltoppslag av enheter"
    },
    {
      "name": "BRREG_API_OPPD",
      "value": "https://data.brreg.no/enhetsregisteret/api/oppdateringer/enheter",
      "description": "Delta-/oppdateringer-endepunkt"
    },
    {
      "name": "BATCH_SIZE",
      "value": "500",
      "description": "Antall oppdateringer per batch"
    }
  ]
}
