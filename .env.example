# Supabase – kopier til .env og fyll inn (.env er gitignored, committes ikke).
# source .env  før du bruker tools/run-sql.sh

# --- HTTPS-vei (Management API) – brukes når Postgres-porten (5432) er stengt ---
# Personal Access Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Prosjekt-ref (står i prosjekt-URL-en og i pooler-brukernavnet)
SUPABASE_PROJECT_REF=ojvqmajyaexisglsykww

# --- Native Postgres-vei (psql / Apache Hop) – krever at 5432 er åpen ut ---
# Session pooler-streng (IPv4). Bytt [PASSORD] med database-passordet.
DATABASE_URL=postgresql://postgres.ojvqmajyaexisglsykww:[PASSORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
